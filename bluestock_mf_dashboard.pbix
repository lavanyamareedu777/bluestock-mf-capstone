assed\":true},\"3301430512\":{\"name\":\"3301430512\",\"rule_id\":\"wAmyXvNaSD7QgQBQPWVMI\",\"secondary_exposures\":[],\"id_type\":\"stableID\",\"value\":{\"enabled\":false},\"is_device_based\":true,\"group_name\":\"Control\",\"is_experiment_active\":true,\"is_user_in_experiment\":true},\"784275017\":{\"name\":\"784275017\",\"rule_id\":\"5E7Fo7tSSOyMTXIiWqvhFh\",\"secondary_exposures\":[],\"id_type\":\"userID\",\"value\":{\"is_enabled\":true},\"is_device_based\":false,\"group_name\":\"Test\",\"is_experiment_active\":true,\"is_user_in_experiment\":true},\"2712016364\":{\"name\":\"2712016364\",\"rule_id\":\"default\",\"secondary_exposures\":[],\"id_type\":\"userID\",\"value\":{\"staleTimeMs\":300001,\"gcTimeMs\":1800001},\"is_device_based\":false,\"passed\":false},\"2328308563\":{\"name\":\"2328308563\",\"rule_id\":\"default\",\"secondary_exposures\":[],\"id_type\":\"stableID\",\"value\":{\"showOptOutIcon\":false,\"label\":\"manage_cookies\"},\"is_device_based\":true,\"passed\":false},\"1939873467\":{\"name\":\"1939873467\",\"rule_id\":\"2d7sRCFGg78Q3JkDtZTTDU\",\"secondary_exposures\":[],\"id_type\":\"userID\",\"value\":{\"enabled\":false},\"is_device_based\":false,\"group_name\":\"Control\",\"is_experiment_active\":true,\"is_user_in_experiment\":true},\"489084288\":{\"name\":\"489084288\",\"rule_id\":\"default\",\"secondary_exposures\":[],\"id_type\":\"stableID\",\"value\":{\"options\":[\"google\",\"apple\",\"microsoft\",\"email\",\"phone_number\"]},\"is_device_based\":true,\"passed\":false},\"217573384\":{\"name\":\"217573384\",\"rule_id\":\"prestart\",\"secondary_exposures\":[],\"id_type\":\"userID\",\"value\":{},\"is_device_based\":false,\"is_experiment_active\":false,\"is_user_in_experiment\":false},\"1977158438\":{\"name\":\"1977158438\",\"rule_id\":\"default\",\"secondary_exposures\":[],\"id_type\":\"userID\",\"value\":{\"user_prompt_key\":\"good_option\",\"system_prompt\":\"The user is asking about an ad shown to them by {advertiser}. Your response must be about the ad shown. They are using the \\\"Ask ChatGPT\\\" feature to get ChatGPT's honest opinion on the product(s) in the advertisement, and in which situations it could be a great fit for them. You should be honest about when you think the product(s) would vs. would not be useful for the user, based on what you know about them.\\n\\nInformation about the ad:\\n{ad}.\\n\\nStructure your response in the following manner:\\n- Briefly describe the type of user, use case, or situation where this ad/product makes sense for the user.\\n- If appropriate, explain any mismatches with the user's stated preferences or goals. That is, where might it fall short for the user (if appropriate)? You don't have to do this for every query, but feel free to list limitations if you think they're pretty relevant.\\n- Give a concise recommendation (e.g., \\\"worth considering,\\\" \\\"probably not ideal,\\\" \\\"good budget option,\\\" \\\"seriously may be a fit,\\\" etc.)\\n\\nGuidelines:\\n- Be honest and practical.\\n- Do not blindly promote the ad.\\n- Avoid harsh or absolute negative language.\\n- Do not invent details not present in the ad.\\n- Focus on fit, not feature lists.\\n- If the mark on relevance is clearly missed, feel free to be funny with it and keep it lighthearted. Do not mock the user or advertiser; keep the humor gentle.\\n\\nKeep it concise, direct, and easy to scan.\\n\\n{conversation}\",\"enable_web_search\":false},\"is_device_based\":false,\"passed\":false},\"349697204\":{\"name\":\"349697204\",\"rule_id\":\"default\",\"secondary_exposures\":[],\"id_type\":\"stableID\",\"value\":{\"codex_mini_models\":[{\"value\":\"gpt-5.5\",\"label\":\"GPT-5.5\"},{\"label\":\"GPT-5.4\",\"value\":\"gpt-5.4\"}],\"changelog_url\":\"https://help.openai.com/en/articles/11428266-codex-changelog\",\"changelog_date\":\"2025-06-13\",\"upgrade_button_message_type\":\"upgrade_to_try_it\",\"availability_message_type\":\"available_to_plus_pro_team_enterprise_and_edu\"},\"is_device_based\":true,\"passed\":false},\"1126845738\":{\"name\":\"1126845738\",\"rule_id\":\"default\",\"secondary_exposures\":[],\"id_type\":\"userID\",\"value\":{\"offices\":{\"sf\":{\"starter_prompt\":\"What is AAPI Heritage Month SF Downtown Block Party ft. Jai Wolf \u0026 Friends, and what happens at the downtown block party?\",\"starter_question\":\"Can you explain the context behind this ChatGPT homepage doodle? It was created for AAPI Heritage Month SF Downtown Block Party ft. Jai Wolf \u0026 Friends in San Francisco, using downtown block-party energy, AAPI celebration, music/DJ set, street-festival atmosphere. What event is it referencing, and how do those details tell the story?\",\"office_label\":\"San Francisco\",\"developer_instructions\":\"The user clicked a ChatGPT homepage doodle. Do not ask them to upload or show the doodle. Concisely explain the event behind the doodle with concrete details: what date \u0026 time the event is in bold, who it centers on or brings together, what the event is, where it happens, why it matters, and how the doodle's visual details connect to that story. Keep the event explanation to at most 1-2 short paragraphs. Make sure you use the right tense for when the event is happening. Use the map widget to ground your answer in the doodle's San Francisco context. If you can identify the most relevant venue, neighborhood, or event location, include it on the map while you explain the doodle. Answer the user's visible prompt using this doodle context:\",\"light_image_url\":\"https://persistent.oaistatic.com/chatgpt/doodles/2026-05-21-to-2026-05-24-manual-dark-oled-review/may-21/sf/may-21_SF_light-mode.png\",\"dark_image_url\":\"https://persistent.oaistatic.com/chatgpt/doodles/2026-05-21-to-2026-05-24-manual-dark-oled-review/may-21/sf/may-21_SF_dark-mode.png\",\"event_title\":\"AAPI Heritage Month SF Downtown Block Party ft. Jai Wolf \u0026 Friends\",\"oled_image_url\":\"https://persistent.oaistatic.com/chatgpt/doodles/2026-05-21-to-2026-05-24-man